# ============================================================
# 운영 배포 환경변수 예시 — docker-compose.prod.yml 용
# 실제 값으로 채워 운영 호스트의 `docker/shop/.env`로 복사(.gitignore 등록됨 — 커밋 금지).
# (로컬 dev용은 .env.example 별도. prod/dev는 같은 호스트에서 동시 기동하지 않음.)
# KEK 파일은 별도: docker/shop/secrets/kek.b64 에 Base64 AES-256 키 배치(커밋 금지).
# ============================================================

# ---- 도메인 / TLS ----
SHOP_DOMAIN=shop.example.com               # 실 도메인(공인 IP의 80/443 인바운드 개방 필요)
LETSENCRYPT_EMAIL=admin@example.com        # Let's Encrypt 갱신 알림 이메일
# 발급 테스트 시 staging 권장(레이트리밋 회피): init-letsencrypt.sh STAGING=1

# ---- 이미지 태그(재현성) ----
SHOP_IMAGE_TAG=latest
NOTIFICATION_IMAGE_TAG=latest
NGINX_IMAGE_TAG=1.27-alpine
CERTBOT_IMAGE_TAG=latest
POSTGRES_IMAGE_TAG=16.4-alpine
KAFKA_IMAGE_TAG=3.8.1
REDIS_IMAGE_TAG=7.4-alpine
ES_IMAGE_TAG=8.15.3     # latest 금지 — 재현성. analysis-nori는 이 ES 버전과 정확히 일치 설치.

# ---- shop-core DB ----
SHOP_CORE_DB_NAME=shop_core
SHOP_CORE_DB_USER=shop_core
SHOP_CORE_DB_PASSWORD=__CHANGE_ME__        # 운영 강 비밀번호

# ---- DB 호스트 포트포워딩(옵션 — 호스트 DB 툴 접속용) ----
# 기본값은 compose에서 127.0.0.1 바인딩(호스트 전용, 외부망 비노출). 아래로 변경 가능:
#   SHOP_CORE_DB_HOST_PORT=127.0.0.1:5432   # 호스트 전용(기본)
#   SHOP_CORE_DB_HOST_PORT=5432             # 모든 인터페이스(0.0.0.0) — 운영 공개망이면 방화벽 필수
# NOTIFICATION_DB_HOST_PORT=127.0.0.1:5433

# ---- notification DB ----
NOTIFICATION_DB_NAME=notification
NOTIFICATION_DB_USER=notification
NOTIFICATION_DB_PASSWORD=__CHANGE_ME__

# ---- 인증(shop-core) ----
# 전 shop-core replica가 동일 값 공유(앵커로 1곳 주입). 32자 이상 필수.
# 생성 예: openssl rand -base64 48
SHOP_SECURITY_JWT_SECRET=__CHANGE_ME_min_32_chars__
# KEK는 .env가 아니라 docker/shop/secrets/kek.b64 파일로 배치(컨테이너 /run/secrets/kek.b64:ro 마운트)
# 생성 예: head -c 32 /dev/urandom | base64 > docker/shop/secrets/kek.b64

# ---- notification 메일(운영 SMTP) ----
NOTIFICATION_MAIL_MODE=smtp
NOTIFICATION_MAIL_FROM=no-reply@shop.example.com
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=__CHANGE_ME__
SPRING_MAIL_PASSWORD=__CHANGE_ME__

# ---- 정적 자산 스토리지 / CDN(shop-core) ----
# 기본값(local): 컨테이너 prod-shop-uploads 볼륨에 저장, 앱 도메인(https://$SHOP_DOMAIN)으로 서빙.
# CDN(R2)로 전환하려면 아래 주석을 해제하고 type=r2 + ASSET_BASE_URL + R2 자격증명을 채운다.
#   - DB에는 storage key만 저장한다(절대 URL 금지). 공개 URL은 ASSET_BASE_URL + key로 합성.
#   - 키/시크릿은 .env로만 주입한다. 평문 커밋 금지.
#   - R2 API 토큰은 'Object Read & Write' 권한 + 대상 버킷(shop-assets) 범위를 반드시 포함해야 한다.
#     (권한/범위 누락 시 업로드가 403 AccessDenied로 실패한다.)
#   - ⚠️ .env는 값에 인라인 주석을 쓰지 말 것. 빈 값 뒤 '# ...'는 값으로 흡수된다(아래 PUBLIC_PREFIX 주의).
#
# SHOP_STORAGE_TYPE=r2
# R2 공개 개발 도메인 또는 커스텀 CDN 도메인
# SHOP_STORAGE_ASSET_BASE_URL=https://pub-xxxxxxxx.r2.dev
# 공개 버킷이면 보통 빈값 — 반드시 값 없이 비워둘 것(같은 줄 주석 금지)
# SHOP_STORAGE_PUBLIC_PREFIX=
# 엔드포인트: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# SHOP_STORAGE_R2_ENDPOINT=https://__ACCOUNT_ID__.r2.cloudflarestorage.com
# SHOP_STORAGE_R2_BUCKET=shop-assets
# SHOP_STORAGE_R2_REGION=auto
# Cloudflare R2 API 토큰 Access Key / Secret Key
# SHOP_STORAGE_R2_ACCESS_KEY=__CHANGE_ME__
# SHOP_STORAGE_R2_SECRET_KEY=__CHANGE_ME__
#
# (선택) 회복탄력성·캐시 오버라이드 — 미설정 시 앱 기본값 사용:
# SHOP_STORAGE_R2_CACHE_CONTROL=public, max-age=31536000, immutable
# SHOP_STORAGE_R2_API_CALL_TIMEOUT_MS=3000
