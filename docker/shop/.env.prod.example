# ============================================================
# 운영 배포 환경변수 예시 — docker-compose.prod.yml 용
# 실제 값으로 채워 운영 호스트의 `docker/shop/.env`로 복사(.gitignore 등록됨 — 커밋 금지).
# (로컬 dev용은 .env.example 별도. prod/dev는 같은 호스트에서 동시 기동하지 않음.)
# KEK 파일은 별도: docker/shop/secrets/kek.b64 에 Base64 AES-256 키 배치(커밋 금지).
# ============================================================

# ---- 도메인 / TLS ----
SHOP_DOMAIN=shop.example.com               # 실 도메인(공인 IP의 80/443 인바운드 개방 필요)
LETSENCRYPT_EMAIL=admin@example.com        # Let's Encrypt 갱신 알림 이메일
# 발급 테스트 시 staging 권장(레이트리밋 회피): init-letsencrypt.sh STAGING=1

# ---- 이미지 태그(재현성) ----
SHOP_IMAGE_TAG=latest
NOTIFICATION_IMAGE_TAG=latest
NGINX_IMAGE_TAG=1.27-alpine
CERTBOT_IMAGE_TAG=latest
POSTGRES_IMAGE_TAG=16.4-alpine
KAFKA_IMAGE_TAG=3.8.1
REDIS_IMAGE_TAG=7.4-alpine

# ---- shop-core DB ----
SHOP_CORE_DB_NAME=shop_core
SHOP_CORE_DB_USER=shop_core
SHOP_CORE_DB_PASSWORD=__CHANGE_ME__        # 운영 강 비밀번호

# ---- notification DB ----
NOTIFICATION_DB_NAME=notification
NOTIFICATION_DB_USER=notification
NOTIFICATION_DB_PASSWORD=__CHANGE_ME__

# ---- 인증(shop-core) ----
# 전 shop-core replica가 동일 값 공유(앵커로 1곳 주입). 32자 이상 필수.
# 생성 예: openssl rand -base64 48
SHOP_SECURITY_JWT_SECRET=__CHANGE_ME_min_32_chars__
# KEK는 .env가 아니라 docker/shop/secrets/kek.b64 파일로 배치(컨테이너 /run/secrets/kek.b64:ro 마운트)
# 생성 예: head -c 32 /dev/urandom | base64 > docker/shop/secrets/kek.b64

# ---- notification 메일(운영 SMTP) ----
NOTIFICATION_MAIL_MODE=smtp
NOTIFICATION_MAIL_FROM=no-reply@shop.example.com
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=__CHANGE_ME__
SPRING_MAIL_PASSWORD=__CHANGE_ME__
