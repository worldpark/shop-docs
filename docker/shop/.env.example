# ============================================================
# 로컬 개발 전용 환경 변수 샘플 — 운영 자격증명 아님
# 이 파일을 .env로 복사 후 필요에 따라 값을 수정한다.
# 실제 .env 파일은 커밋하지 말 것 (.gitignore 등록 필수).
# 이 파일(.env.example)만 커밋한다.
# ============================================================
# SSOT: docker/shop/docker-compose.yml 기본값과 docs/plans/infra/003-infra-local-docker-compose-plan.md 1-1 표.
# compose는 .env 없이도 기본값으로 기동된다. 포트 충돌 시에만 여기서 재정의한다.
# ============================================================

# ------- shop-core PostgreSQL (호스트 포트: 5432) --------
# 앱 접속: jdbc:postgresql://localhost:5432/shop_core
SHOP_CORE_DB_NAME=shop_core
SHOP_CORE_DB_USER=shop_core
SHOP_CORE_DB_PASSWORD=shop_core   # 로컬 전용 — 운영 시 강한 패스워드로 교체
SHOP_CORE_DB_PORT=5432            # 호스트 포트 충돌 시 변경 (앱 yml도 동시에 변경 필요)

# ------- notification PostgreSQL (호스트 포트: 5433) ------
# 앱 접속: jdbc:postgresql://localhost:5433/notification
NOTIFICATION_DB_NAME=notification
NOTIFICATION_DB_USER=notification
NOTIFICATION_DB_PASSWORD=notification   # 로컬 전용 — 운영 시 강한 패스워드로 교체
NOTIFICATION_DB_PORT=5433               # 호스트 포트 충돌 시 변경 (앱 yml도 동시에 변경 필요)

# ------- Kafka (EXTERNAL 호스트 포트: 9092) ---------------
# 앱 bootstrap-servers: localhost:9092
# 주의: KAFKA_EXTERNAL_PORT 변경 시 앱 yml의 bootstrap-servers도 함께 변경해야 함
#       (EXTERNAL advertised listener와 반드시 일치 필요)
KAFKA_EXTERNAL_PORT=9092

# ------- Redis (호스트 포트: 6379) ------------------------
# 로컬 전용 단일 Redis — AUTH/TLS 없음. 운영 보안/클러스터 구성과 무관.
# DB index 분리: shop-core=0, notification=1 (앱 application.yml과 동기)
# SSOT: docker/shop/docker-compose.yml 기본값과 동기. 포트 충돌 시 변경.
# 변경 시 앱 yml의 SHOP_CORE_REDIS_PORT / NOTIFICATION_REDIS_PORT도 함께 변경 필요.
REDIS_PORT=6379

# ------- 이미지 태그 (latest 금지 — 재현성 보장) ----------
POSTGRES_IMAGE_TAG=16.4-alpine
KAFKA_IMAGE_TAG=3.8.1   # apache/kafka 공식 이미지 태그 (KRaft 기본, ZooKeeper 불필요)
REDIS_IMAGE_TAG=7.4-alpine  # latest 금지 — 재현성 보장
ES_IMAGE_TAG=8.15.3     # latest 금지 — 재현성. analysis-nori는 이 ES 버전과 정확히 일치 설치.

# ------- Elasticsearch 검색 엔진 (ADR-011 T1) -------------
# 호스트 포트 충돌 시 변경. 앱 SHOP_CORE_SEARCH_URIS도 동시 변경 필요.
SHOP_CORE_SEARCH_PORT=9200

# ------- Kafka Cluster ID (후보 B 전용 — 통상 미사용) -----
# apache/kafka:3.8.1 이미지는 첫 기동 시 자동으로 cluster id를 생성·포맷한다(후보 A).
# 자동 포맷이 실패하는 경우에만 아래 주석을 해제하고 고정 UUID를 입력한다(후보 B).
# 후보 B 사용 시: kafka 로그 디렉터리에 named volume을 추가하고 docker compose down -v 후 재기동.
# KAFKA_CLUSTER_ID=<kafka-storage random-uuid 결과 입력>
